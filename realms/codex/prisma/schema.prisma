generator client {
  provider      = "prisma-client-js"
  output        = "./generated"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Archetype {
  id         String
  universeId String @map("universe_id")
  kind       String
  name       String
  payload    Json

  @@id([universeId, id])
  @@index([universeId, kind])
  @@map("archetype")
}
