{
  "name": "zok",
  "private": true,
  "version": "0.0.1",
  "bin": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias",
    "start": "node ./dist/index.js",
    "test": "tsx --test test/**/*.test.ts",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "commander": "^14.0.3",
    "date-fns": "^4.1.0",
    "lodash": "^4.18.1",
    "nanoid": "^5.1.7",
    "nunjucks": "^3.2.4",
    "prettier": "^3.8.2",
    "source-map-support": "^0.5.21",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@dod/config": "*",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/nunjucks": "^3.2.6",
    "eslint": "^10.2.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
