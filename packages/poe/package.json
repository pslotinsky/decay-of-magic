{
  "name": "@dod/poe",
  "version": "0.0.1",
  "private": true,
  "bin": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias",
    "test": "tsx --test 'test/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "devDependencies": {
    "@dod/config": "*",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "lodash": "^4.18.1"
  }
}
