{
  "name": "@dod/poe",
  "version": "0.0.1",
  "private": true,
  "bin": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias",
    "test": "tsx --test 'test/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "docs": "poe inspect"
  },
  "devDependencies": {
    "@dod/config": "*",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "lodash": "^4.18.1",
    "zod": "^4.4.2"
  }
}
