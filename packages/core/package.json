{
  "name": "@dod/core",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./collection": {
      "types": "./dist/collection/index.d.ts",
      "default": "./dist/collection/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "docs": "poe inspect"
  },
  "dependencies": {
    "@dod/api-contract": "*"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "rxjs": "^7.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@dod/config": "*",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "rxjs": "^7.8.2",
    "typescript": "^6.0.3",
    "zod": "^4.3.6"
  }
}
