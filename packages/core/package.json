{
  "name": "@dod/core",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "docs": "poe inspect"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0"
  },
  "devDependencies": {
    "@dod/config": "*",
    "@nestjs/common": "^11.1.18",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2"
  }
}
