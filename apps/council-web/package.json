    "react-router": "^7.14.0"
  },
  "devDependencies": {
    "@dod/config": "*",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "sass-embedded": "^1.99.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.8"
