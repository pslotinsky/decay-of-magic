{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["DATABASE_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "prisma:generate"],
      "outputs": ["dist/**"]
    },
    "prisma:generate": {
      "outputs": ["../../node_modules/.prisma/client/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "test:unit": {
      "dependsOn": ["^build"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "typecheck": {},
    "format": {
      "cache": false
    },
    "format:check": {
      "cache": false
    },
    "docs": {
      "dependsOn": ["@dod/poe#build"],
      "cache": false
    }
  }
}
